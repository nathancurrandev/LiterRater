{
  "name": "literrater-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "migrate": "mikro-orm migration:up",
    "migrate:create": "mikro-orm migration:create",
    "seed:admin": "ts-node src/scripts/seedAdmin.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mikro-orm/core": "^6.0.0",
    "@mikro-orm/mysql": "^6.0.0",
    "@mikro-orm/migrations": "^6.0.0",
    "@mikro-orm/cli": "^6.0.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "next": "^14.0.0",
    "cookie": "^0.6.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cookie": "^0.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2"
  },
  "mikro-orm": {
    "useTsNode": true,
    "configPaths": ["./mikro-orm.config.ts"]
  }
